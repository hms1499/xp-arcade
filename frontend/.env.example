# Single shared registry contract for all games (Snake/Tetris/Pac-Man/XP Bricks).
NEXT_PUBLIC_CONTRACT_ADDRESS=SP2CMK69QNY60HBG8BJ4X5TD7XX2ZT4XB62V13SV.xp-arcade-v4
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_APP_URL=https://xp-snake.vercel.app
# Soft deadline for the current season (ISO 8601 UTC). Display-only — the
# contract does not enforce it. Owner must still manually call end-season
# around this time. Change requires redeploy.
NEXT_PUBLIC_SEASON_END_ISO=2026-06-30T23:59:59Z
# Remote browser (Browserbase) for the in-app "Internet" window. Server-side
# only. Without these, the Internet window falls back to iframe + open-in-tab.
# keepAlive sessions require a paid Browserbase plan.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# --- Bitflow mini swap (STX <-> sBTC) ---
# From the Bitflow dashboard / SDK config. Required for the Swap window to
# fetch quotes and execute swaps. Without these the Swap window still renders
# but quotes/swaps will fail. Client-side (NEXT_PUBLIC_).
NEXT_PUBLIC_BITFLOW_API_HOST=
NEXT_PUBLIC_BITFLOW_PROVIDER_ADDRESS=
NEXT_PUBLIC_BITFLOW_READONLY_HOST=
NEXT_PUBLIC_BITFLOW_API_KEY=
